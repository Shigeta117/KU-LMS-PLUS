{
  "manifest_version": 3,
  "name": "KU-KMS+ スクレイパー",
  "short_name": "KU-KMS+",
  "version": "1.0.0",
  "description": "関西大学 WebClass の課題を自動収集して Supabase に保存します",

  "permissions": ["storage", "scripting", "webNavigation", "tabs"],
  "host_permissions": [
    "https://kulms.tl.kansai-u.ac.jp/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "KU-KMS+",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
